POSTGRES_PASSWORD=<secure-password>
NEWS_APP_PASSWORD=<secure-password-for-app-user>
REGISTRY=<your-registry-url>
CORS_ORIGINS=http://localhost:3100,http://localhost:3000
PUBLIC_API_URL=https://api.example.com
API_KEYS=<key1>,<key2>
ENVIRONMENT=development
PUBLIC_URL=https://news.example.com
REGISTRY=<your-registry-url>
REGISTRY_TEST=<your-test-registry-url>
# ...
# Host interface for the API port mapping (deploy compose).
# Default 127.0.0.1 = loopback only (recommended for production where n8n is co-located).
# Set 0.0.0.0 to expose externally (test environments; API_KEYS-protected).
API_BIND_ADDR=127.0.0.1
